<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0c1324"
    android:id="@+id/main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ─── SURFACE CARD ─── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#151b2d">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- ─── HEADER ─── -->
                <TextView
                    android:id="@+id/tvCardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buat akun baru"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#dce1fb"
                    android:letterSpacing="-0.02"
                    android:lineSpacingMultiplier="1.15"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Isi semua field untuk menyelesaikan registrasi akun kamu."
                    android:textSize="14sp"
                    android:textColor="#6b7399"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_marginBottom="48dp" />

                <!-- ─── SECTION: Informasi Akun ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INFORMASI AKUN"
                    android:textSize="11sp"
                    android:textColor="#44485a"
                    android:letterSpacing="0.08"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <!-- NAMA -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama lengkap *"
                    android:textSize="13sp"
                    android:textColor="#8b91b3"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNama"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxBackgroundColor="#0c1324"
                    app:boxStrokeColor="@color/midnight_input_stroke"
                    app:boxStrokeWidth="1dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNama"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:hint="Masukkan nama lengkap"
                        android:textSize="14sp"
                        android:textColor="#dce1fb"
                        android:textColorHint="#2e3447"
                        android:inputType="textPersonName"
                        android:background="@null" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email *"
                    android:textSize="13sp"
                    android:textColor="#8b91b3"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxBackgroundColor="#0c1324"
                    app:boxStrokeColor="@color/midnight_input_stroke"
                    app:boxStrokeWidth="1dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:hint="nama@email.com"
                        android:textSize="14sp"
                        android:textColor="#dce1fb"
                        android:textColorHint="#2e3447"
                        android:inputType="textEmailAddress"
                        android:background="@null" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password *"
                    android:textSize="13sp"
                    android:textColor="#8b91b3"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxBackgroundColor="#0c1324"
                    app:boxStrokeColor="@color/midnight_input_stroke"
                    app:boxStrokeWidth="1dp"
                    app:hintEnabled="false"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#44485a">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:hint="Min. 8 karakter"
                        android:textSize="14sp"
                        android:textColor="#dce1fb"
                        android:textColorHint="#2e3447"
                        android:inputType="textPassword"
                        android:background="@null" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvPasswordHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"
                    android:text="Minimal 8 karakter"
                    android:textSize="12sp"
                    android:textColor="#44485a" />

                <!-- CONFIRM PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Konfirmasi password *"
                    android:textSize="13sp"
                    android:textColor="#8b91b3"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilConfirmPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxBackgroundColor="#0c1324"
                    app:boxStrokeColor="@color/midnight_input_stroke"
                    app:boxStrokeWidth="1dp"
                    app:hintEnabled="false"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#44485a">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:hint="Ulangi password"
                        android:textSize="14sp"
                        android:textColor="#dce1fb"
                        android:textColorHint="#2e3447"
                        android:inputType="textPassword"
                        android:background="@null" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvPasswordError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:text="Password tidak cocok"
                    android:textSize="12sp"
                    android:textColor="#ff8a8a"
                    android:visibility="gone" />

                <!-- ─── SECTION: Jenis Kelamin ─── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="28dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JENIS KELAMIN"
                        android:textSize="11sp"
                        android:textColor="#8b91b3"
                        android:letterSpacing="0.08"
                        android:textStyle="bold" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/rgJenisKelamin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <RadioButton
                        android:id="@+id/rbLakiLaki"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Laki-laki"
                        android:textSize="14sp"
                        android:textColor="@color/midnight_radio_text"
                        android:button="@null"
                        android:background="@drawable/bg_radio_midnight"
                        android:gravity="center"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rbPerempuan"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:text="Perempuan"
                        android:textSize="14sp"
                        android:textColor="@color/midnight_radio_text"
                        android:button="@null"
                        android:background="@drawable/bg_radio_midnight"
                        android:gravity="center" />
                </RadioGroup>

                <!-- ─── SECTION: Hobi ─── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HOBI"
                        android:textSize="11sp"
                        android:textColor="#8b91b3"
                        android:letterSpacing="0.08"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/flexboxHobi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:flexWrap="wrap"
                    app:alignItems="flex_start"
                    app:justifyContent="flex_start">

                    <CheckBox
                        android:id="@+id/cbOlahraga"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_margin="4dp"
                        android:text="Olahraga"
                        android:textSize="13sp"
                        android:textColor="@color/midnight_cb_text"
                        android:button="@null"
                        android:background="@drawable/bg_checkbox_midnight"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cbMusik"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_margin="4dp"
                        android:text="Musik"
                        android:textSize="13sp"
                        android:textColor="@color/midnight_cb_text"
                        android:button="@null"
                        android:background="@drawable/bg_checkbox_midnight"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cbCoding"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_margin="4dp"
                        android:text="Coding"
                        android:textSize="13sp"
                        android:textColor="@color/midnight_cb_text"
                        android:button="@null"
                        android:background="@drawable/bg_checkbox_midnight"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cbMemasak"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_margin="4dp"
                        android:text="Memasak"
                        android:textSize="13sp"
                        android:textColor="@color/midnight_cb_text"
                        android:button="@null"
                        android:background="@drawable/bg_checkbox_midnight"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cbMembaca"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_margin="4dp"
                        android:text="Membaca"
                        android:textSize="13sp"
                        android:textColor="@color/midnight_cb_text"
                        android:button="@null"
                        android:background="@drawable/bg_checkbox_midnight"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:gravity="center" />

                    <CheckBox
                        android:id="@+id/cbGaming"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_margin="4dp"
                        android:text="Gaming"
                        android:textSize="13sp"
                        android:textColor="@color/midnight_cb_text"
                        android:button="@null"
                        android:background="@drawable/bg_checkbox_midnight"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:gravity="center" />
                </com.google.android.flexbox.FlexboxLayout>

                <TextView
                    android:id="@+id/tvHobiCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="0dp"
                    android:text="0 hobi dipilih — pilih minimal 3"
                    android:textSize="12sp"
                    android:textColor="#ff8a8a" />

                <!-- ─── SECTION: Kota Asal ─── -->
                <View android:layout_width="match_parent" android:layout_height="48dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:text="KOTA ASAL"
                    android:textSize="11sp"
                    android:textColor="#44485a"
                    android:letterSpacing="0.08"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerKota"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="48dp"
                    android:background="@drawable/bg_spinner_midnight"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:popupBackground="#191f31"
                    android:spinnerMode="dropdown" />

                <!-- ─── BUTTONS ─── -->
                <Button
                    android:id="@+id/btnDaftar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Daftar sekarang"
                    android:textSize="15sp"
                    android:textColor="#0c1324"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary_midnight"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:text="Reset form"
                    android:textSize="13sp"
                    android:textColor="#6b7399"
                    android:background="@drawable/bg_button_ghost_midnight"
                    android:stateListAnimator="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:text="TAHAN TOMBOL DAFTAR UNTUK LONG PRESS ACTION"
                    android:textSize="9sp"
                    android:textColor="#2e3447"
                    android:letterSpacing="0.06"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>